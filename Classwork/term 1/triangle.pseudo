BEGIN Triangle

    GET SideA
    Get SideB
    Get SideC

    IF SideC * SideC = (SideA * SideA + SideB * SideB) THEN
        PRINT "Right Angled Triangle"
    ELSE IF SideA = SideB AND SideB = SideC THEN
        PRINT "Equilateral Triangle"
    ELSE IF SideA = SideB OR SideA = SideC OR SideB = Side C THEN
         Print "Isocles Triangle"
    ELSE
        Print "Scalene Triangle"
    ELSE IF
END 
